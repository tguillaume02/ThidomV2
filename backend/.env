# ThiDom Backend

# Database
DATABASE_URL=sqlite+aiosqlite:///./thidom.db

# JWT Auth
SECRET_KEY=thidom-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# InfluxDB (for time-series history)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=thidom-influx-token
INFLUXDB_ORG=thidom
INFLUXDB_BUCKET=thidom_history

# MQTT (optional plugin)
MQTT_BROKER=localhost
MQTT_PORT=1883

# Telegram (optional plugin)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Timezone
TIMEZONE=Europe/Paris
