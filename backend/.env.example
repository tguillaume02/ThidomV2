# =============================================================================
# ThiDom Backend - Fichier de configuration (TEMPLATE)
#
# Copiez ce fichier vers .env et renseignez les valeurs :
#   cp .env.example .env
#
# NE COMMITEZ JAMAIS le fichier .env (il contient des secrets).
# install.sh genere automatiquement .env avec des cles aleatoires.
# =============================================================================

# Database (genere par install.sh)
# SQLite :    sqlite+aiosqlite:///./data/thidom.db
# MariaDB :   mysql+aiomysql://thidom:PASSWORD@localhost:3306/thidom
# PostgreSQL: postgresql+asyncpg://thidom:PASSWORD@localhost:5432/thidom
DATABASE_URL=sqlite+aiosqlite:///./data/thidom.db

# JWT Auth (SECRET_KEY est generee automatiquement si absente)
# SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# InfluxDB (optionnel, pour l'historique time-series)
# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=thidom
# INFLUXDB_BUCKET=thidom_history

# MQTT (optionnel)
# MQTT_BROKER=localhost
# MQTT_PORT=1883

# Telegram (optionnel)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Timezone
TIMEZONE=Europe/Paris
